# PostgreSQL connection
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/riverside?schema=public"

# Auth.js (NextAuth v5) — production'da zorunlu
# Oluşturmak için: openssl rand -base64 32
AUTH_SECRET="generate-with: openssl rand -base64 32"
# Yerel geliştirme
AUTH_URL="http://localhost:3000"
# Vercel'de: https://SITENIZ.vercel.app (sonunda / olmadan)
# Vercel otomatik AUTH_URL atayabilir; trustHost kodda açık.

# HotelRunner Custom Apps API
# Henüz kimlik bilgileriniz yoksa boş bırakın; sistem otomatik olarak mock moduna geçer.
HOTELRUNNER_HR_ID=""
HOTELRUNNER_TOKEN=""
HOTELRUNNER_API_BASE="https://app.hotelrunner.com"
# Webhook doğrulaması için paylaşılan gizli anahtar
HOTELRUNNER_WEBHOOK_SECRET=""

# Mock modu zorla (kimlik bilgileri olsa bile): "true" / "false"
HOTELRUNNER_FORCE_MOCK="true"

# Yönetim panelinde sunum/demo verileri göster (PostgreSQL olmadan da çalışır)
ADMIN_DEMO_MODE="true"
